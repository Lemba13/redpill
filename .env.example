# Copy to .env and fill in your values

# Required for web search (https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Required only if delivery_method = "email"
SMTP_PASSWORD=your_smtp_password_here

# Suppresses a cosmetic "unauthenticated requests" warning from huggingface_hub.
# all-MiniLM-L6-v2 is a public model — no HF account needed.
# If you later use private models or hit rate limits, replace with a real token:
#   HF_TOKEN=hf_...
HUGGINGFACE_HUB_VERBOSITY=error

# Required Ollama models — pull before running:
#   ollama pull llama3.1:8b       (or your preferred summarization model — see ollama_config.model)
#   ollama pull qwen3.5:4b        (reasoning model for two-stage query planning — see planner_llm.model)
#
# The planner model (qwen3.5:4b) is only used when query_planning.enabled = true.
# If qwen3.5:4b is unavailable, set planner_llm.model to the same model as
# ollama_config.model and set planner_llm.think: false for a simpler planning path.
